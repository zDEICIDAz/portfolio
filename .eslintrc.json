{
  "extends": [
    "@rocketseat/eslint-config/next",
    "next/core-web-vitals"
  ],
  "rules": {
    "prettier/prettier": ["error", {
      "printWidth": 100,
      "tabWidth": 2,
      "singleQuote": true,
      "jsxSingleQuote": false,
      "trailingComma": "all",
      "arrowParens": "avoid",
      "semi": true,
      "endOfLine": "auto"
    }]
  }
}